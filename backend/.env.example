# ══════════════════════════════════════════════════════════════════════════════
# ParkiPay — Backend Environment Variables Template
# Copy this file to .env and fill in your real values.
# This file (.env.example) IS committed to git — it has no real secrets.
# The actual .env file is in .gitignore and must NEVER be committed.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
ALLOWED_HOSTS=https://your-app-name.onrender.com

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=replace-with-a-long-random-secret

# ── Database (Supabase pooler — use port 6543, not 5432) ─────────────────────
# Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# ── Auth Policy ───────────────────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPT=10
LOCKOUT_DURATION_MINUTES=15

# ── Billing ───────────────────────────────────────────────────────────────────
CONTROL_NUMBER_VALIDITY_HOURS=5

# ── Redis (Upstash — for queues / caching / future background jobs) ──────────
# Create a free Redis DB at https://upstash.com → copy the TLS connection URL
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# ── Africa's Talking (SMS) ────────────────────────────────────────────────────
# Sign up at https://africastalking.com
# Use AT_USERNAME=sandbox + AT_SANDBOX=True for development (free, no real SMS)
# Switch to your real username + AT_SANDBOX=False for production
AT_USERNAME=sandbox
AT_API_KEY=replace-with-your-africastalking-api-key
AT_SENDER_ID=ParkiPay
AT_SANDBOX=True

# ── Resend (Email notifications) ──────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create
RESEND_API_KEY=re_replace-with-your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# ── Render Deploy Hook (used by GitHub Actions CD) ────────────────────────────
# Render → your service → Settings → Deploy Hooks → Create new hook
# Also add this as a GitHub Secret named RENDER_DEPLOY_HOOK_URL
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-[id]?key=[key]

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=False
