# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://parkipay:parkipay@localhost:5432/parkipay

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# ── Auth policy ───────────────────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── Billing ───────────────────────────────────────────────────────────────────
CONTROL_NUMBER_VALIDITY_HOURS=5

# ── Africa's Talking (SMS) ───────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=ParkiPay
