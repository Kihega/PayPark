# ParkiPay Mobile — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to git (it is in .gitignore).
#
# ── API URL ──────────────────────────────────────────────────────────────────
# Local dev (Termux):      http://YOUR_LAN_IP:8000
# Android emulator:        http://10.0.2.2:8000
# Staging / Production:    https://parkipay-api.onrender.com
#
# Get your LAN IP in Termux: ip addr show | grep "inet " | grep -v 127
#
EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
